% ============================================================
% usctitle.sty
% Style file for H. R. 9510 Bill v4.0 (single-prompt-bill, auto-bill-01).
%   THE GRAY-SCALE MERMAID AMENDMENT to the Federal Food, Drug, and Cosmetic Act
%   (21 U.S.C. 301 et seq.), built on the Title 21 device provisions current
%   through Public Law 119-93.
%
% WHAT THIS STYLE IS. It descends from the VVUQ-05 final-bill style
% (usctitle.sty, v3.1.0). It keeps the United States Code look and feel for
% reproduced existing-law text (Times-like serif, bold section catchlines,
% hanging-indent statutory hierarchy, centered cross-headings, small-caps note
% headings, parenthetical source credits) and the apparatus of a congressional
% amendment (the bill caption, the "A BILL" head, the enacting clause, run-in
% bill-section catchlines, the comparative-print strike and insert markers, and a
% clickable, page-filling table of contents). The v4.0 change: the ASCII figure
% primitive is replaced by a GRAY-SCALE MERMAID figure rendered natively in TikZ
% (a white-background, black-ruled, centered box), so every diagram is a
% gray-scale Mermaid diagram with no raster image and the document still compiles
% in Overleaf with pdfLaTeX. A verbatim listing box is retained only for
% repository-structure trees (file listings, not diagrams).
%
% Senior-author formatting required by the task is centralized here:
%   - body text is RaggedRight (ragged2e) with a small RaggedRightRightskip
%     stretch so interword spacing is even, with no rivers, no large gaps, and no
%     line running off the right margin;
%   - widow, orphan, and broken-line penalties are maximal so no single line is
%     stranded and no one- or two-word last line is left behind;
%   - the running header is abbreviated so no two fields overlap;
%   - long reference URLs break on any character so no link runs off the page;
%   - left-aligned ragged-right fixed-width columns (L and ragcol) and a flexible
%     ragged-right column (Y) set every table to the body measure;
%   - every background is white; black rules only;
%   - single hyphens only; the section symbol for every codified reference.
% ============================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{usctitle}[2026/06/07 v4.0.0 Food, Drug, and Cosmetic Act gray-scale Mermaid amendment style]

% - Times-like serif body to match the printed United States Code. newtx is
%   standard on Overleaf; on a minimal install substitute \usepackage{mathptmx}. -
\RequirePackage{newtxtext}
\RequirePackage{newtxmath}

% - Page geometry: letter paper, statute-style measure. -
\RequirePackage[letterpaper,top=1.0in,bottom=1.0in,left=1.1in,right=1.1in,%
  headheight=15pt,headsep=18pt,footskip=24pt]{geometry}

% - Color, encodings, and the typesetting helpers. -
\RequirePackage{xcolor}
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
\RequirePackage{textcomp}
\RequirePackage[protrusion=true,expansion=false]{microtype}
\RequirePackage{array}
\RequirePackage{longtable}
\RequirePackage{tabularx}
\RequirePackage{xltabular}
\RequirePackage{ragged2e}
\RequirePackage{needspace}
\RequirePackage{enumitem}
\RequirePackage{fancyvrb}

% - TikZ for the gray-scale Mermaid figures (no external image is used). -
\RequirePackage{tikz}
\usetikzlibrary{shapes.geometric,arrows.meta,positioning,fit,backgrounds,calc}

% - Hyperref for PDF bookmarks and the clickable contents; links are black. -
\RequirePackage[hidelinks,pdfusetitle]{hyperref}
\RequirePackage{url}

% - White background everywhere; black rules only. -
\definecolor{billwhite}{rgb}{1,1,1}
\definecolor{billblack}{rgb}{0,0,0}
\pagecolor{billwhite}

% - Five-step gray-scale palette for the Mermaid figures: lightest for inputs and
%   context, darkest for end goals and the bill, with decisions and law between. -
\definecolor{mmg1}{gray}{0.96}
\definecolor{mmg2}{gray}{0.88}
\definecolor{mmg3}{gray}{0.81}
\definecolor{mmg4}{gray}{0.72}
\definecolor{mmg5}{gray}{0.60}

% - Even spacing, no right-margin overflow, no big interword gaps. -
\tolerance=2000
\emergencystretch=3em
\hbadness=4000
\hyphenpenalty=70
\exhyphenpenalty=70
\RaggedRight
\setlength{\RaggedRightParindent}{0pt}
\setlength{\RaggedRightRightskip}{0pt plus 2em}

% - No stranded lines: maximal widow, orphan, and broken-line penalties. -
\widowpenalty=10000
\clubpenalty=10000
\displaywidowpenalty=10000
\brokenpenalty=10000
\interlinepenalty=0
\predisplaypenalty=10000
\postdisplaypenalty=10000

% - Break long URLs on any character so no reference link runs off the margin. -
\def\UrlBreaks{\do\/\do-\do.\do=\do_\do?\do\&\do\%\do\#\do\:\do\a\do\b\do\c%
\do\d\do\e\do\f\do\g\do\h\do\i\do\j\do\k\do\l\do\m\do\n\do\o\do\p\do\q\do\r%
\do\s\do\t\do\u\do\v\do\w\do\x\do\y\do\z\do\A\do\B\do\C\do\D\do\E\do\F\do\G%
\do\H\do\I\do\J\do\K\do\L\do\M\do\N\do\O\do\P\do\Q\do\R\do\S\do\T\do\U\do\V%
\do\W\do\X\do\Y\do\Z\do\0\do\1\do\2\do\3\do\4\do\5\do\6\do\7\do\8\do\9}
\Urlmuskip=0mu plus 3mu\relax

% The ieeetr bibliography style lowercases title fields, so a \S in a BibTeX title
% is emitted as \s; provide \s as the section symbol so the bibliography compiles.
\providecommand{\s}{\S}

% - Paragraph defaults: small inter-clause gap, no first-line indent. -
\setlength{\parindent}{0pt}
\setlength{\parskip}{3.2pt plus 1pt minus 0.5pt}

% - Running header: page left, abbreviated act title center, bill number right. -
\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0pt}
\fancyhead[L]{\footnotesize\thepage}
\fancyhead[C]{\footnotesize\scshape Verification Before Generation Act of 2026}
\fancyhead[R]{\footnotesize H.\,R. 9510 (Bill v4.0)}
\fancypagestyle{plain}{%
  \fancyhf{}%
  \renewcommand{\headrulewidth}{0pt}%
  \fancyfoot[C]{\footnotesize\thepage}}

% - Indentation unit for the statutory hierarchy. -
\newlength{\uscunit}\setlength{\uscunit}{1.7em}

% - Left-aligned, ragged-right fixed-width table columns. -
\newcolumntype{L}[1]{>{\raggedright\arraybackslash}p{#1}}
\newcolumntype{Y}{>{\raggedright\arraybackslash}X}
\newcommand{\ragcol}[1]{>{\raggedright\arraybackslash}p{#1}}

% ==========================================================================
% UNITED STATES CODE REPRODUCTION COMMANDS (existing-law text, comparative print).
% ==========================================================================
\newcommand{\usctitlehead}[2]{%
  \begin{center}
  {\Large\bfseries #1}\\[0.25em]
  {\Large\bfseries #2}
  \end{center}}

\newcommand{\uscchapterhead}[2]{%
  \par\addvspace{1.4\baselineskip}%
  \needspace{4\baselineskip}%
  \phantomsection\addcontentsline{toc}{section}{#1 #2}%
  \begin{center}{\large\bfseries #1\\[0.15em]#2}\end{center}%
  \par\addvspace{0.5\baselineskip}}

\newcommand{\uscsubchapterhead}[1]{%
  \par\addvspace{1.1\baselineskip}%
  \needspace{3\baselineskip}%
  \phantomsection\addcontentsline{toc}{subsection}{#1}%
  \begin{center}{\bfseries #1}\end{center}%
  \par\addvspace{0.35\baselineskip}}

\newcommand{\uscparthead}[1]{%
  \par\addvspace{0.8\baselineskip}%
  \needspace{3\baselineskip}%
  \phantomsection\addcontentsline{toc}{subsection}{#1}%
  \begin{center}{\bfseries\scshape #1}\end{center}%
  \par\addvspace{0.3\baselineskip}}

% Section catchline.
\newcommand{\uscsection}[2]{%
  \par\addvspace{1.15\baselineskip}%
  \needspace{4\baselineskip}%
  \phantomsection
  \addcontentsline{toc}{subsubsection}{#1 #2}%
  {\setlength{\parindent}{0pt}\bfseries\large #1\hskip 0.45em #2\par}%
  \nopagebreak\par\addvspace{0.35\baselineskip}}

% Statutory provision with a hanging indent at depth #1 (0 = flush body).
\newcommand{\uscprov}[2]{%
  \par
  \begingroup
  \ifnum#1>0
    \setlength{\leftskip}{\dimexpr#1\uscunit\relax}%
    \setlength{\parindent}{-\uscunit}%
  \else
    \setlength{\leftskip}{0pt}%
    \setlength{\parindent}{1.0em}%
  \fi
  #2\par
  \endgroup}

% Quoted statutory or amendment text, indented and set off.
\newcommand{\uscquote}[2]{%
  \par
  \begingroup
  \setlength{\leftskip}{\dimexpr#1\uscunit + \uscunit\relax}%
  \setlength{\rightskip}{0.5\uscunit}%
  \setlength{\parindent}{0.8em}%
  \small #2\par
  \endgroup}

% Source credit: parenthetical Public Law lineage at the left margin.
\newcommand{\uscsource}[1]{%
  \par\addvspace{0.25\baselineskip}%
  {\setlength{\parindent}{0pt}\small #1\par}%
  \addvspace{0.2\baselineskip}}

% Cross-heading: centered bold.
\newcommand{\usccrosshead}[1]{%
  \par\addvspace{0.7\baselineskip}%
  \needspace{2.5\baselineskip}%
  \begin{center}{\bfseries #1}\end{center}%
  \par\addvspace{0.2\baselineskip}}

% Note heading: centered small caps.
\newcommand{\uscnotehead}[1]{%
  \par\addvspace{0.45\baselineskip}%
  \needspace{2\baselineskip}%
  \begin{center}{\scshape #1}\end{center}%
  \par\addvspace{0.1\baselineskip}}

% Note paragraph: flush body text within a note.
\newcommand{\uscnotepar}[1]{%
  \par{\setlength{\parindent}{1.0em}#1\par}}

% Boxed operative sentence (used by the Constitutional Authority Statement).
\newcommand{\billbox}[1]{%
  \par\addvspace{0.4\baselineskip}%
  \begin{center}\begin{minipage}{0.92\linewidth}%
  \setlength{\fboxrule}{0.5pt}\setlength{\fboxsep}{8pt}%
  \fcolorbox{billblack}{billwhite}{\begin{minipage}{\dimexpr\linewidth-18pt\relax}#1\end{minipage}}%
  \end{minipage}\end{center}%
  \par\addvspace{0.4\baselineskip}}

% Font-independent empty checkbox (for the cosponsor and currency checklists).
\providecommand{\cboxx}{\raisebox{0.12ex}{\framebox[1.25ex]{\rule{0pt}{0.95ex}}}}

% Signature line (for the sponsor and cosponsor packet).
\newcommand{\sigline}[1]{\par\addvspace{0.5\baselineskip}%
  \noindent\rule{0.5\linewidth}{0.4pt}\\[-1pt]{\footnotesize #1}\par}

% ==========================================================================
% CONGRESSIONAL AMENDMENT APPARATUS.
% ==========================================================================
\newcommand{\billcaption}[3]{%
  \begin{center}
  \makebox[\textwidth][s]{\bfseries #1\hfill #3}\\[0.15em]
  {\itshape #2}
  \end{center}%
  \vspace{0.2em}\noindent\rule{\textwidth}{0.8pt}\par}

\newcommand{\billlongtitle}[1]{%
  \par\addvspace{0.4\baselineskip}%
  \begin{center}\begin{minipage}{0.86\textwidth}\centering #1\end{minipage}\end{center}%
  \par\addvspace{0.3\baselineskip}}

\newcommand{\billintro}[3]{%
  \par\addvspace{0.3\baselineskip}%
  \begin{center}{\scshape #1}\\[0.2em]{\itshape #2}\end{center}%
  \par{\setlength{\parindent}{1.0em}#3\par}%
  \par\addvspace{0.3\baselineskip}}

\newcommand{\billhead}{%
  \par\addvspace{0.5\baselineskip}%
  \noindent\rule{\textwidth}{0.8pt}\par
  \begin{center}\vspace{0.1cm}{\LARGE\bfseries A BILL}\vspace{-0.2cm}\end{center}%
  \noindent\rule{\textwidth}{0.8pt}\par
  \addvspace{0.3\baselineskip}}

\newcommand{\enactingclause}{%
  \par\addvspace{0.3\baselineskip}%
  {\itshape This legislative draft is submitted for review and consideration by the United States Congress,}\par
  \addvspace{0.4\baselineskip}}

\newcommand{\billcovernote}[1]{%
  \par\addvspace{0.4\baselineskip}%
  \begingroup
  \footnotesize\itshape\RaggedRight
  \setlength{\parindent}{0pt}%
  \noindent\rule{\linewidth}{0.4pt}\par\vspace{2pt}%
  #1\par
  \vspace{-3pt}\noindent\rule{\linewidth}{0.4pt}\par
  \endgroup
  \addvspace{0.4\baselineskip}}

\newcommand{\billsec}[2]{%
  \par\addvspace{0.9\baselineskip}%
  \needspace{4\baselineskip}%
  \phantomsection
  \addcontentsline{toc}{section}{#1 #2}%
  {\setlength{\parindent}{0pt}\bfseries #1\hskip 0.4em #2\par}%
  \nopagebreak\par\addvspace{0.2\baselineskip}}

% Comparative-print markers: deleted shown [strike: ...]; inserted [insert: ...].
\newcommand{\cprstrike}[1]{[strike: #1]}
\newcommand{\cprinsert}[1]{[insert: \textit{#1}]}

% ==========================================================================
% CLICKABLE, PAGE-FILLING TABLE OF CONTENTS (SECTION 1(b)).
% ==========================================================================
\newcommand{\billtoc}[1]{%
  \par
  \begingroup
  \setlength{\parindent}{0pt}%
  \setlength{\parskip}{0pt}%
  #1%
  \par
  \endgroup}

\newcommand{\billtocline}[4]{%
  \needspace{2.2\baselineskip}%
  {\setlength{\leftskip}{0pt}\setlength{\rightskip}{0pt}%
   \noindent\hyperref[#1]{\bfseries #2\hskip 0.4em \mdseries #3}%
   \nobreak\ \dotfill\ \hyperref[#1]{\pageref{#1}}\par}%
  {\footnotesize\itshape\setlength{\leftskip}{1.8em}\setlength{\rightskip}{0pt plus 2em}%
   #4\par}}

% ==========================================================================
% VISUAL PRIMITIVES.
% ==========================================================================
% Gray-scale Mermaid figure styles (TikZ). Node roles match the Stage 3 palette
% g1..g5; emphasis is by gray level and stroke weight only (no color).
\tikzset{
  mmevery/.style={>={Stealth[length=2.2mm]},line width=0.5pt,font=\footnotesize,
    every node/.append style={align=center}},
  mmin/.style={rectangle,rounded corners=2pt,draw=billblack,fill=mmg1,
    minimum height=8mm,inner sep=3pt,text width=30mm},
  mmstep/.style={rectangle,rounded corners=2pt,draw=billblack,fill=mmg2,
    minimum height=8mm,inner sep=3pt,text width=30mm},
  mmdec/.style={diamond,aspect=2,draw=billblack,fill=mmg3,inner sep=1pt,
    text width=22mm},
  mmlaw/.style={rectangle,rounded corners=2pt,draw=billblack,line width=0.8pt,
    fill=mmg4,minimum height=8mm,inner sep=3pt,text width=30mm},
  mmgoal/.style={rectangle,rounded corners=2pt,draw=billblack,line width=1pt,
    fill=mmg5,minimum height=8mm,inner sep=3pt,text width=32mm},
  mmperson/.style={ellipse,draw=billblack,fill=mmg1,inner sep=2pt,
    text width=24mm,minimum height=9mm},
  mmlane/.style={rectangle,draw=billblack,dashed,inner sep=5pt,rounded corners=1pt},
  mmlanetitle/.style={font=\scriptsize\bfseries},
  mmedge/.style={->,draw=billblack},
  mmedged/.style={->,draw=billblack,dashed},
  mmlabel/.style={font=\scriptsize\itshape,fill=billwhite,inner sep=1pt}
}

% mermaidfig: capture a tikzpicture into a content-width box, then frame it on
% white and center it on the page, mirroring the prior asciifig placement.
\newsavebox{\mmsavebox}
\newenvironment{mermaidfig}{%
  \par\addvspace{0.55\baselineskip}%
  \needspace{8\baselineskip}%
  \begin{lrbox}{\mmsavebox}%
  \begin{tikzpicture}[mmevery]%
}{%
  \end{tikzpicture}%
  \end{lrbox}%
  \begin{center}%
  \setlength{\fboxrule}{0.4pt}\setlength{\fboxsep}{8pt}%
  \fcolorbox{billblack}{billwhite}{\usebox{\mmsavebox}}%
  \end{center}%
  \par\addvspace{0.15\baselineskip}}

% Repository-structure / file-listing box (a verbatim listing, not a diagram):
% a white-background, black-ruled monospace box that preserves spacing exactly,
% sized to content and centered, for directory trees only.
\newsavebox{\treebox}
\newcommand{\treeplace}{%
  \begin{center}%
  \setlength{\fboxrule}{0.4pt}\setlength{\fboxsep}{8pt}%
  \fcolorbox{billblack}{billwhite}{\usebox{\treebox}}%
  \end{center}%
  \par\addvspace{0.15\baselineskip}}
\newenvironment{treelisting}{%
  \VerbatimEnvironment
  \par\addvspace{0.5\baselineskip}%
  \needspace{6\baselineskip}%
  \begin{lrbox}{\treebox}%
  \begin{BVerbatim}[fontsize=\footnotesize,baselinestretch=0.96]%
}{%
  \end{BVerbatim}%
  \end{lrbox}%
  \treeplace}

% Figure or table caption: small centered italic line. Single hyphens only.
\newcommand{\figcaption}[1]{%
  \par\nopagebreak
  \begin{center}\begin{minipage}{0.9\linewidth}%
  \centering\footnotesize\itshape #1%
  \end{minipage}\end{center}%
  \addvspace{0.5\baselineskip}}

\endinput
